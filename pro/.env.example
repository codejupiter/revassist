REVASSIST_SESSION_SECRET=replace-with-a-long-random-secret
REVASSIST_AI_MODE=mock
REVASSIST_MODEL=openai/gpt-5.4

# Optional. When set, RevAssist Pro uses Neon/Postgres instead of the in-memory local adapter.
DATABASE_URL=postgres://user:password@host.neon.tech/dbname?sslmode=require
REVASSIST_REQUIRE_DATABASE=false

# Optional. When set, RevAssist Pro uses Upstash Redis instead of the in-memory rate limiter.
UPSTASH_REDIS_REST_URL=https://example.upstash.io
UPSTASH_REDIS_REST_TOKEN=replace-with-upstash-token
# Vercel Marketplace Upstash Redis may provide KV_REST_API_URL and KV_REST_API_TOKEN instead.
KV_REST_API_URL=
KV_REST_API_TOKEN=
REVASSIST_REQUIRE_DURABLE_RATE_LIMIT=false
REVASSIST_RATE_LIMIT_PREFIX=revassist:rate

# Optional live AI credentials. Use Vercel AI Gateway or a provider key.
REVASSIST_LIVE_EVAL_MODEL=openai/gpt-5.4
AI_GATEWAY_API_KEY=
OPENAI_API_KEY=
