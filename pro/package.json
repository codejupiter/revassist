{
  "name": "revassist-pro",
  "description": "Fullstack AI deal desk OS for powersports F&I teams.",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "next dev --port 3010",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit --pretty false",
    "test": "vitest run",
    "test:watch": "vitest",
    "eval": "tsx scripts/run-evals.ts",
    "eval:json": "tsx scripts/run-evals.ts --json",
    "eval:report": "tsx scripts/run-evals.ts --report docs/EVAL_BASELINE.md",
    "eval:live": "tsx scripts/run-live-evals.ts",
    "eval:live:json": "tsx scripts/run-live-evals.ts --json",
    "eval:live:report": "tsx scripts/run-live-evals.ts --report docs/LIVE_EVAL_SNAPSHOT.md",
    "eval:live:required": "tsx scripts/run-live-evals.ts --require-live",
    "smoke": "playwright test",
    "smoke:ui": "playwright test --ui"
  },
  "dependencies": {
    "@neondatabase/serverless": "^1.1.0",
    "@upstash/redis": "^1.38.0",
    "ai": "^6.0.184",
    "jose": "^6.2.3",
    "lucide-react": "^1.14.0",
    "next": "16.2.6",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "zod": "^4.4.3"
  },
  "overrides": {
    "next": {
      "postcss": "8.5.10"
    }
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/node": "^25.9.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "eslint": "^10.4.0",
    "eslint-config-next": "16.2.6",
    "tsx": "^4.22.2",
    "typescript": "^6.0.3",
    "vitest": "^4.1.6"
  }
}
